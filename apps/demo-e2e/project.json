{
  "name": "demo-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/demo-e2e/src",
  "projectType": "application",
  "tags": [
    "type:e2e",
    "platform:web"
  ],
  "implicitDependencies": [
    "demo"
  ],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx tsc --project apps/demo-e2e/tsconfig.json --noEmit"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx playwright test --config apps/demo-e2e/playwright.config.ts"
      }
    }
  }
}
