{
  "name": "@koloda/native-electron-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "tags": [
    "type:app",
    "platform:web"
  ],
  "sourceRoot": "apps/native-electron-react/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/native-electron-react",
        "configFile": "apps/native-electron-react/vite.config.ts"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "build",
        "port": 3000
      },
      "configurations": {
        "development": {
          "buildTarget": "build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "build:production"
        }
      }
    },
    "lingui-extract": {
      "executor": "nx:run-script",
      "options": {
        "script": "lingui extract"
      }
    },
    "linge": {
      "executor": "nx:run-script",
      "options": {
        "script": "lingui extract --clean"
      }
    },
    "lingui-compile": {
      "executor": "nx:run-script",
      "options": {
        "script": "lingui compile"
      }
    },
    "lingc": {
      "executor": "nx:run-script",
      "options": {
        "script": "lingui compile"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx vitest run --config apps/native-electron-react/vitest.config.mjs --configLoader runner"
      },
      "inputs": ["default", "^default"],
      "configurations": {}
    }
  }
}
